# Google OAuth for Chrome Extension
VITE_EXTENSION_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Navix API Proxy (Cloud Functions)
VITE_NAVIX_PROXY_URL=https://us-central1-your-project-id.cloudfunctions.net/navixApiProxy

# Firebase Configuration - Get from Firebase Console
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
